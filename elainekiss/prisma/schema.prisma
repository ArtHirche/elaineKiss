// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  description String
  price       Float    // Dica: No futuro, use Int (centavos) para evitar erros de arredondamento
  imageUrl    String
  slug        String   @unique // Para URL amigável: /produto/caneta-azul
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Order {
  id            String   @id @default(uuid())
  customerName  String
  customerCPF   String
  totalAmount   Float
  status        String   @default("PENDING") // PENDING, PAID, SHIPPED
  pixCode       String?  // O código copia e cola
  createdAt     DateTime @default(now())
}